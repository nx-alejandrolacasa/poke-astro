---
import { PokemonSearch } from '@/components/PokemonSearch'
import type { Locale } from '@/utils/i18n'
import { getAlternateLocale, localizeUrl } from '@/utils/i18n'
import { translations } from '@/utils/translations'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = translations[locale]
const altLocale = getAlternateLocale(locale)
const currentPath = Astro.url.pathname
---

<header
  data-site-header
  class="sticky top-0 z-40 w-full px-5 pt-[calc(env(safe-area-inset-top)+0.75rem)] transition-transform duration-300 ease-out will-change-transform sm:px-6 sm:pt-[calc(env(safe-area-inset-top)+1rem)]"
>
  <nav class="mx-auto flex h-12 max-w-4xl items-center gap-2 rounded-full border border-white/60 bg-white/70 px-4 shadow-lg shadow-black/[0.04] backdrop-blur-2xl transition-colors sm:h-14 sm:gap-3 sm:px-5 dark:border-white/[0.08] dark:bg-dark-surface/70 dark:shadow-black/20">
    <!-- Logo -->
    <a
      href={`/${locale}`}
      title="Home"
      class="flex-shrink-0 transition-transform active:scale-95 hover:scale-105"
    >
      <img
        src="/pokemon-logo.svg"
        alt="Pokemon"
        class="h-5 w-auto sm:h-6 lg:h-7"
      />
    </a>

    <!-- Desktop nav links — pill-highlight on active, inline layout -->
    <div class="hidden items-center gap-1 lg:flex ml-2">
      <a
        href={`/${locale}/pokedex`}
        class:list={[
          'flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-semibold transition-all',
          currentPath.startsWith(`/${locale}/pokedex`)
            || currentPath.startsWith(`/${locale}/pokemon/`)
            || currentPath.startsWith(`/${locale}/type/`)
            || currentPath.startsWith(`/${locale}/generation/`)
            ? 'bg-primary/12 text-primary dark:bg-dark-primary/15 dark:text-dark-primary'
            : 'text-ink-muted hover:bg-black/5 hover:text-ink dark:text-dark-ink-muted dark:hover:bg-white/8 dark:hover:text-dark-ink'
        ]}
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <line x1="2" y1="12" x2="8.5" y2="12" />
          <line x1="15.5" y1="12" x2="22" y2="12" />
          <circle cx="12" cy="12" r="3.5" />
        </svg>
        <span>{t.header.pokedex}</span>
      </a>
      <a
        href={`/${locale}/types`}
        class:list={[
          'flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-semibold transition-all',
          currentPath.startsWith(`/${locale}/types`)
            ? 'bg-primary/12 text-primary dark:bg-dark-primary/15 dark:text-dark-primary'
            : 'text-ink-muted hover:bg-black/5 hover:text-ink dark:text-dark-ink-muted dark:hover:bg-white/8 dark:hover:text-dark-ink'
        ]}
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z" />
        </svg>
        <span>{t.header.typeChart}</span>
      </a>
    </div>

    <!-- Desktop search -->
    <div class="hidden flex-1 justify-center lg:flex">
      <div class="w-full max-w-sm">
        <PokemonSearch client:load locale={locale} />
      </div>
    </div>

    <!-- Spacer on mobile -->
    <div class="flex-1 lg:hidden"></div>

    <!-- Language switcher -->
    <a
      href={localizeUrl(currentPath, altLocale)}
      class="flex flex-shrink-0 items-center gap-1 rounded-full px-2.5 py-1 text-sm font-medium text-ink-muted transition-all hover:bg-black/5 dark:text-dark-ink-muted dark:hover:bg-white/8"
      title={altLocale === 'en' ? 'Switch to English' : 'Cambiar a Espanol'}
    >
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="9" />
        <path d="M3.6 9h16.8M3.6 15h16.8" />
        <path d="M12 3c2 2.5 3 5.5 3 9s-1 6.5-3 9c-2-2.5-3-5.5-3-9s1-6.5 3-9z" />
      </svg>
      <span>{locale.toUpperCase()}</span>
    </a>

    <!-- Theme toggle (custom element defined in Layout.astro) -->
    <theme-toggle data-locale={locale} class="flex-shrink-0"></theme-toggle>
  </nav>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector('[data-site-header]')
    if (!header) return

    const SAFE_ZONE = 90
    const HIDDEN_CLASS = '-translate-y-full'
    const mobile = window.matchMedia('(max-width: 1023px)')

    function clampedScrollY() {
      const doc = document.documentElement
      const max = Math.max(0, (doc.scrollHeight || document.body.scrollHeight) - window.innerHeight)
      return Math.max(0, Math.min(window.scrollY, max))
    }

    let lastY = clampedScrollY()
    let ticking = false

    function update() {
      ticking = false
      if (!mobile.matches) {
        header.classList.remove(HIDDEN_CLASS)
        lastY = clampedScrollY()
        return
      }
      const y = clampedScrollY()
      if (y <= SAFE_ZONE) {
        header.classList.remove(HIDDEN_CLASS)
      } else if (y > lastY) {
        header.classList.add(HIDDEN_CLASS)
      } else if (y < lastY) {
        header.classList.remove(HIDDEN_CLASS)
      }
      lastY = y
    }

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(update)
          ticking = true
        }
      },
      { passive: true },
    )
    mobile.addEventListener('change', update)
  })()
</script>
