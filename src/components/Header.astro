---
import { HeaderActions } from '@/components/HeaderActions'
import { PokemonSearchWrapper } from '@/components/PokemonSearchWrapper'
import type { Locale } from '@/utils/i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
---

<header class="chromatic-header-shadow sticky top-0 z-40 w-full border-b border-black/[0.06] bg-white/90 backdrop-blur-xl transition-colors dark:border-white/[0.06] dark:bg-dark-surface/90">
  <nav class="mx-auto flex h-14 max-w-5xl items-center gap-4 px-4 sm:h-16 sm:px-6">
    <!-- Pokemon logo home link -->
    <a
      href={`/${locale}`}
      title="Home"
      class="flex-shrink-0 transition-transform active:scale-95 hover:scale-105"
    >
      <img
        src="/pokemon-logo.svg"
        alt="Pokemon"
        class="h-6 w-auto sm:h-7"
      />
    </a>

    <!-- Search -->
    <div class="flex-1 flex justify-center">
      <div class="w-full max-w-md">
        <PokemonSearchWrapper client:load locale={locale} />
      </div>
    </div>

    <!-- Settings -->
    <HeaderActions client:load locale={locale} />
  </nav>
</header>
