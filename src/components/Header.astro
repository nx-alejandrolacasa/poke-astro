---
import { HeaderSettings } from '@/components/HeaderSettings'
import { PokemonSearch } from '@/components/PokemonSearch'
import type { Locale } from '@/utils/i18n'
import { translations } from '@/utils/translations'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = translations[locale]
const currentPath = Astro.url.pathname
---

<header class="sticky top-0 z-40 hidden w-full px-5 pt-[calc(env(safe-area-inset-top)+0.75rem)] sm:px-6 sm:pt-[calc(env(safe-area-inset-top)+1rem)] lg:block">
  <nav class="mx-auto flex h-12 max-w-4xl items-center gap-2 rounded-full border border-white/60 bg-white/70 px-3.5 shadow-lg shadow-black/[0.04] backdrop-blur-xl transition-colors sm:h-14 sm:gap-3 dark:border-white/[0.08] dark:bg-dark-surface/70 dark:shadow-black/20">
    <!-- Desktop nav links — pill-highlight on active, inline layout -->
    <div class="flex items-center gap-1">
      <a
        href={`/${locale}`}
        class:list={[
          'flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-semibold text-primary transition-all dark:text-dark-primary',
          currentPath === `/${locale}` || currentPath === `/${locale}/`
            ? 'bg-primary/12 dark:bg-dark-primary/15'
            : 'hover:bg-primary/8 dark:hover:bg-dark-primary/10'
        ]}
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span>{t.header.home}</span>
      </a>
      <a
        href={`/${locale}/pokedex`}
        class:list={[
          'flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-semibold text-red-500 transition-all dark:text-red-300',
          currentPath.startsWith(`/${locale}/pokedex`)
            || currentPath.startsWith(`/${locale}/pokemon/`)
            || currentPath.startsWith(`/${locale}/type/`)
            || currentPath.startsWith(`/${locale}/generation/`)
            ? 'bg-red-500/12 dark:bg-red-500/15'
            : 'hover:bg-red-500/8 dark:hover:bg-red-500/10'
        ]}
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <line x1="2" y1="12" x2="8.5" y2="12" />
          <line x1="15.5" y1="12" x2="22" y2="12" />
          <circle cx="12" cy="12" r="3.5" />
        </svg>
        <span>{t.header.pokedex}</span>
      </a>
      <a
        href={`/${locale}/types`}
        class:list={[
          'flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-semibold text-yellow-600 transition-all dark:text-yellow-400',
          currentPath.startsWith(`/${locale}/types`)
            ? 'bg-yellow-500/15 dark:bg-yellow-500/20'
            : 'hover:bg-yellow-500/8 dark:hover:bg-yellow-500/10'
        ]}
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z" />
        </svg>
        <span>{t.header.typeChart}</span>
      </a>
    </div>

    <!-- Right group: settings + search, mirrors the mobile nav order -->
    <div class="ml-auto flex items-center gap-2">
      <HeaderSettings client:load locale={locale} currentPath={currentPath} />
      <div class="w-full max-w-sm">
        <PokemonSearch client:load locale={locale} />
      </div>
    </div>
  </nav>
</header>
