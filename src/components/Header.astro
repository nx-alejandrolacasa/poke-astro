---
import { HeaderActions } from '@/components/HeaderActions'
import { PokemonSearchWrapper } from '@/components/PokemonSearchWrapper'
import type { Locale } from '@/utils/i18n'

interface Props {
  locale: Locale
}

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const { locale } = Astro.props
---

<header class="sticky top-0 z-40 border-b border-gray-200 bg-white/95 shadow-sm backdrop-blur-md transition-colors dark:border-dex-border dark:bg-dex-panel/95">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav class="flex h-14 items-center justify-between gap-4 sm:h-16 md:gap-8">
      <!-- Logo / Branding -->
      <a
        href={`/${locale}`}
        title="Go home"
        class="flex-shrink-0 transition-transform hover:scale-105"
      >
        <span class="font-display font-bold text-lg tracking-widest uppercase text-gray-900 sm:text-xl dark:bg-gradient-to-r dark:from-neon-blue dark:to-neon-cyan dark:bg-clip-text dark:text-transparent">
          Pokédex
        </span>
      </a>

      <!-- Search - Hidden on mobile, shown on tablet+ -->
      <div class="hidden flex-1 sm:flex sm:justify-center sm:px-4">
        <div class="w-full max-w-lg">
          <PokemonSearchWrapper client:load locale={locale} />
        </div>
      </div>

      <!-- Actions -->
      <HeaderActions client:load locale={locale} />
    </nav>
  </div>
  <!-- Glow line under header (dark mode only) -->
  <div class="hidden dark:block glow-line"></div>
</header>
