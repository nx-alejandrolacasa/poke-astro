---
import { HeaderActions } from '@/components/HeaderActions'
import { PokemonSearchWrapper } from '@/components/PokemonSearchWrapper'
import type { Locale } from '@/utils/i18n'

interface Props {
  locale: Locale
}

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const { locale } = Astro.props
---

<header class="sticky top-0 z-40 border-b border-gray-200 bg-white/95 backdrop-blur-md transition-colors dark:border-dex-border dark:bg-dex-panel/95">
  <div class="mx-auto max-w-7xl px-3 sm:px-6 lg:px-8">
    <nav class="flex h-12 items-center gap-3 sm:h-14">
      <!-- Pokéball home link -->
      <a
        href={`/${locale}`}
        title="Home"
        class="flex-shrink-0 transition-transform active:scale-90 hover:scale-105"
      >
        <svg class="h-7 w-7 sm:h-8 sm:w-8" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5" class="text-gray-300 dark:text-dex-border" />
          <path d="M1 12h8.5m5 0H23" stroke="currentColor" stroke-width="1.5" class="text-gray-300 dark:text-dex-border" />
          <circle cx="12" cy="12" r="11" fill="none" />
          <path d="M12 1a11 11 0 0 1 0 22" fill="currentColor" class="text-primary-500 dark:text-primary" />
          <path d="M12 1a11 11 0 0 0 0 22" fill="currentColor" class="text-white dark:text-dex-surface" />
          <path d="M1 12h8.5a2.5 2.5 0 0 1 5 0H23" stroke="currentColor" stroke-width="1.5" class="text-gray-400 dark:text-gray-600" />
          <circle cx="12" cy="12" r="2.5" fill="currentColor" stroke="currentColor" stroke-width="1" class="text-white dark:text-gray-300" />
          <circle cx="12" cy="12" r="1.5" fill="currentColor" class="text-gray-400 dark:text-gray-500" />
        </svg>
      </a>

      <!-- Search — always visible -->
      <div class="flex-1">
        <PokemonSearchWrapper client:load locale={locale} />
      </div>

      <!-- Gear icon -->
      <HeaderActions client:load locale={locale} />
    </nav>
  </div>
  <div class="hidden dark:block glow-line"></div>
</header>
