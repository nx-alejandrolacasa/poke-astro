---
import type { Locale } from '@/utils/i18n'
import { FooterContent } from './FooterContent'

interface Props {
  locale: Locale
}

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const { locale } = Astro.props
---

<footer class="mt-12 border-t border-gray-200 bg-white/95 transition-colors dark:border-dex-border dark:bg-dex-panel/95">
  <div class="hidden dark:block glow-line"></div>
  <div class="mx-auto max-w-7xl px-6 py-6">
    <FooterContent locale={locale} />
  </div>
</footer>
