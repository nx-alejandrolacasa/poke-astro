---
import { TypeChart } from '@/components/TypeChart'
import Layout from '@/layouts/Layout.astro'
import { getI18n } from '@/utils/i18n'

const { locale: localeParam } = Astro.params
const { locale } = getI18n(localeParam)

const title = locale === 'es' ? 'Tabla de Tipos' : 'Type Chart'
---

<Layout title={title} locale={locale}>
  <TypeChart client:load locale={locale} />
</Layout>
