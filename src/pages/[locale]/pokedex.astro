---
export const prerender = true

import ListerSkeleton from '@/components/ListerSkeleton.astro'
import { PokemonInfiniteScroll } from '@/components/PokemonInfiniteScroll'
import Layout from '@/layouts/Layout.astro'
import { getI18n, getLocalePaths } from '@/utils/i18n'
import { fetchPokemonPage } from '@/utils/pokemon'

export function getStaticPaths() {
  return getLocalePaths()
}

const { locale: localeParam } = Astro.params
const { locale, t } = getI18n(localeParam)

const initialData = await fetchPokemonPage(1)
---

<Layout title={t.header.pokedex} locale={locale}>
  <PokemonInfiniteScroll client:only="react" initialData={initialData} locale={locale}>
    <ListerSkeleton slot="fallback" />
  </PokemonInfiniteScroll>
</Layout>
