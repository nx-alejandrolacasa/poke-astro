---
import { GenerationInfiniteScroll } from '@/components/GenerationInfiniteScroll'
import Layout from '@/layouts/Layout.astro'
import { getI18n } from '@/utils/i18n'
import type { Pokemon, PokemonList } from '@/utils/pokemon'
import { fetchGenerationData, fetchPokemonByNames } from '@/utils/pokemon'

const generations: Record<
  string,
  { nameEn: string; nameEs: string; region: string }
> = {
  '1': { nameEn: 'Generation I', nameEs: 'Generación I', region: 'Kanto' },
  '2': { nameEn: 'Generation II', nameEs: 'Generación II', region: 'Johto' },
  '3': { nameEn: 'Generation III', nameEs: 'Generación III', region: 'Hoenn' },
  '4': { nameEn: 'Generation IV', nameEs: 'Generación IV', region: 'Sinnoh' },
  '5': { nameEn: 'Generation V', nameEs: 'Generación V', region: 'Unova' },
  '6': { nameEn: 'Generation VI', nameEs: 'Generación VI', region: 'Kalos' },
  '7': { nameEn: 'Generation VII', nameEs: 'Generación VII', region: 'Alola' },
  '8': {
    nameEn: 'Generation VIII',
    nameEs: 'Generación VIII',
    region: 'Galar',
  },
  '9': { nameEn: 'Generation IX', nameEs: 'Generación IX', region: 'Paldea' },
}

const { locale: localeParam, id = '' } = Astro.params
const { locale, t } = getI18n(localeParam)

const generationData = generations[id]
if (!generationData) {
  return Astro.redirect(`/${locale}/404`)
}

const generation = {
  id: Number(id),
  name: locale === 'es' ? generationData.nameEs : generationData.nameEn,
  region: generationData.region,
}

const genColors: Record<number, string> = {
  1: 'from-red-600 to-blue-600',
  2: 'from-yellow-500 to-purple-600',
  3: 'from-blue-600 to-green-600',
  4: 'from-purple-600 to-pink-600',
  5: 'from-gray-700 to-blue-700',
  6: 'from-pink-500 to-blue-500',
  7: 'from-orange-500 to-blue-600',
  8: 'from-cyan-600 to-purple-700',
  9: 'from-red-600 to-purple-600',
}

const gradientClass = genColors[generation.id] || 'from-gray-400 to-gray-500'

let genData
try {
  genData = await fetchGenerationData(generation.id)
} catch {
  return Astro.redirect(`/${locale}/404`)
}

genData.pokemon_species.sort((a: { url: string }, b: { url: string }) => {
  const idA = Number(a.url.split('/').filter(Boolean).pop())
  const idB = Number(b.url.split('/').filter(Boolean).pop())
  return idA - idB
})

const pageSize = 30
const speciesSlice = genData.pokemon_species.slice(0, pageSize)

const speciesNames = speciesSlice.map((species: { name: string }) => species.name)
const results: Pokemon[] = (await fetchPokemonByNames(speciesNames)).sort(
  (a, b) => a.id - b.id
)

const initialData: PokemonList = {
  count: genData.pokemon_species.length,
  results,
}
---

<Layout title={`${generation.name} - ${generation.region} ${t.pages.region}`} locale={locale}>
  <GenerationInfiniteScroll
    client:load
    initialData={initialData}
    generation={generation}
    generationColor={gradientClass}
    locale={locale}
  />
</Layout>
